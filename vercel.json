{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "node_modules/ffmpeg-static/ffmpeg,node_modules/@napi-rs/canvas-*/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/download/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*\\.(?:js|css|png|ico|json|svg|webp))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
